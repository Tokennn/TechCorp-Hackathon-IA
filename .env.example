# Copiez ce fichier en `.env.local` puis renseignez les valeurs.
# (`.env.local` est ignoré par git — n'y mettez jamais de secret dans un fichier suivi.)

# --- Authentification Clerk (obligatoire) ---
# Clé PUBLIQUE (front) — dashboard.clerk.com → API Keys.
# pk_test_... en développement, pk_live_... en production.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Clé SECRÈTE (back uniquement) — ne PAS exposer côté front.
# Inutile tant que l'app est front-only ; requise si un backend Clerk est ajouté.
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# --- Serveur d'inférence (équipe Infra / IA) ---
# URL du serveur d'inférence (ex : Ollama)
VITE_INFERENCE_URL=http://localhost:11434

# Nom du modèle servi
VITE_MODEL=phi3.5-financial
